<mxGraphModel>
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>

    <!-- Title -->
    <mxCell id="title" value="Daily Stock Analysis - 数据链路图（单股分析流程）" style="text;html=1;fontSize=16;fontStyle=1;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#1a1a2e;" vertex="1" parent="1">
      <mxGeometry x="100" y="8" width="600" height="28" as="geometry"/>
    </mxCell>

    <!-- Step 1: Input -->
    <mxCell id="input" value="用户请求&#xa;stock_code + report_type" style="shape=parallelogram;rounded=1;fillColor=#5c6bc0;fontColor=#ffffff;strokeColor=#3949ab;fontSize=11;fontStyle=1;perimeter=parallelogramPerimeter;size=15;" vertex="1" parent="1">
      <mxGeometry x="290" y="42" width="200" height="42" as="geometry"/>
    </mxCell>

    <!-- Step 2: Data Fetch Phase (parallel) -->
    <mxCell id="fetch_group" value="" style="rounded=1;fillColor=#e3f2fd;strokeColor=#1e88e5;opacity=40;arcSize=6;dashed=1;" vertex="1" parent="1">
      <mxGeometry x="30" y="110" width="740" height="95" as="geometry"/>
    </mxCell>
    <mxCell id="fetch_label" value="[1-4] 数据采集阶段（并行）" style="text;html=1;fontSize=11;fontStyle=1;align=left;fillColor=none;strokeColor=none;fontColor=#1565c0;" vertex="1" parent="1">
      <mxGeometry x="40" y="112" width="200" height="18" as="geometry"/>
    </mxCell>

    <mxCell id="fetch_daily" value="历史行情&#xa;get_daily_data()&#xa;→ DataFrame (OHLC)" style="rounded=1;fillColor=#1e88e5;fontColor=#ffffff;strokeColor=#1565c0;fontSize=10;whiteSpace=wrap;" vertex="1" parent="1">
      <mxGeometry x="40" y="135" width="155" height="55" as="geometry"/>
    </mxCell>
    <mxCell id="fetch_rt" value="实时行情&#xa;get_realtime_quote()&#xa;→ RealtimeQuote" style="rounded=1;fillColor=#1e88e5;fontColor=#ffffff;strokeColor=#1565c0;fontSize=10;whiteSpace=wrap;" vertex="1" parent="1">
      <mxGeometry x="215" y="135" width="155" height="55" as="geometry"/>
    </mxCell>
    <mxCell id="fetch_chip" value="筹码分布&#xa;get_chip_distribution()&#xa;→ ChipDistribution" style="rounded=1;fillColor=#1e88e5;fontColor=#ffffff;strokeColor=#1565c0;fontSize=10;whiteSpace=wrap;" vertex="1" parent="1">
      <mxGeometry x="390" y="135" width="160" height="55" as="geometry"/>
    </mxCell>
    <mxCell id="fetch_fund" value="基本面&#xa;get_fundamental_context()&#xa;→ FundamentalContext" style="rounded=1;fillColor=#1e88e5;fontColor=#ffffff;strokeColor=#1565c0;fontSize=10;whiteSpace=wrap;" vertex="1" parent="1">
      <mxGeometry x="570" y="135" width="170" height="55" as="geometry"/>
    </mxCell>

    <!-- Step 5: Technical Analysis -->
    <mxCell id="tech" value="[5] 技术分析&#xa;StockTrendAnalyzer.analyze(df)&#xa;→ TrendAnalysisResult&#xa;(trend_status / MA alignment / RSI / MACD / buy_signal)" style="rounded=1;fillColor=#43a047;fontColor=#ffffff;strokeColor=#2e7d32;fontSize=10;fontStyle=1;whiteSpace=wrap;" vertex="1" parent="1">
      <mxGeometry x="40" y="230" width="330" height="60" as="geometry"/>
    </mxCell>

    <!-- Step 6: News -->
    <mxCell id="news" value="[6] 新闻情报&#xa;SearchService.search(code, name)&#xa;→ SearchResponse&#xa;(formatted_news / risk_alerts / catalysts)" style="rounded=1;fillColor=#43a047;fontColor=#ffffff;strokeColor=#2e7d32;fontSize=10;fontStyle=1;whiteSpace=wrap;" vertex="1" parent="1">
      <mxGeometry x="400" y="230" width="340" height="60" as="geometry"/>
    </mxCell>

    <!-- Merge point -->
    <mxCell id="merge" value="" style="rhombus;fillColor=#ef6c00;strokeColor=#e65100;fontColor=#ffffff;fontSize=10;" vertex="1" parent="1">
      <mxGeometry x="370" y="315" width="30" height="30" as="geometry"/>
    </mxCell>
    <mxCell id="merge_label" value="汇聚 6 维数据" style="text;html=1;fontSize=10;fontStyle=2;align=left;fillColor=none;strokeColor=none;fontColor=#e65100;" vertex="1" parent="1">
      <mxGeometry x="410" y="320" width="100" height="18" as="geometry"/>
    </mxCell>

    <!-- Step 7: AI Analysis -->
    <mxCell id="ai" value="[7] AI 综合分析 — GeminiAnalyzer.analyze()&#xa;入参: TrendAnalysisResult + RealtimeQuote + ChipDistribution + FundamentalContext + SearchResponse + MarketContext&#xa;出参: AnalysisResult (sentiment_score / decision_type / dashboard / risk_warning)" style="rounded=1;fillColor=#ef6c00;fontColor=#ffffff;strokeColor=#e65100;fontSize=10;fontStyle=1;whiteSpace=wrap;" vertex="1" parent="1">
      <mxGeometry x="80" y="365" width="620" height="65" as="geometry"/>
    </mxCell>

    <!-- Integrity Check -->
    <mxCell id="integrity" value="内容完整性校验&#xa;check_content_integrity()" style="shape=hexagon;rounded=1;fillColor=#ffa726;fontColor=#ffffff;strokeColor=#ef6c00;fontSize=10;fontStyle=1;perimeter=hexagonPerimeter2;size=12;" vertex="1" parent="1">
      <mxGeometry x="265" y="450" width="180" height="40" as="geometry"/>
    </mxCell>

    <!-- Step 8: Format -->
    <mxCell id="format_step" value="[8] 报告格式化&#xa;Formatters → MD / JSON / HTML / Image" style="rounded=1;fillColor=#7b1fa2;fontColor=#ffffff;strokeColor=#6a1b9a;fontSize=10;fontStyle=1;whiteSpace=wrap;" vertex="1" parent="1">
      <mxGeometry x="80" y="510" width="250" height="42" as="geometry"/>
    </mxCell>

    <!-- Step 9: Notify -->
    <mxCell id="notify_step" value="[9] 多渠道推送&#xa;NotificationService → WeChat / Feishu /&#xa;Telegram / Email / Slack / Discord ..." style="rounded=1;fillColor=#7b1fa2;fontColor=#ffffff;strokeColor=#6a1b9a;fontSize=10;fontStyle=1;whiteSpace=wrap;" vertex="1" parent="1">
      <mxGeometry x="390" y="505" width="260" height="52" as="geometry"/>
    </mxCell>

    <!-- Step 10: Persist -->
    <mxCell id="persist" value="[10] 持久化 — DatabaseManager&#xa;StockDaily / AnalysisReport / AnalysisContext / NewsIntel" style="rounded=1;fillColor=#455a64;fontColor=#ffffff;strokeColor=#37474f;fontSize=10;fontStyle=1;whiteSpace=wrap;" vertex="1" parent="1">
      <mxGeometry x="165" y="575" width="430" height="40" as="geometry"/>
    </mxCell>

    <!-- External data sources (bottom) -->
    <mxCell id="ext_ds" value="外部数据源: Akshare / Tushare / YFinance / Longbridge / Baostock / E-Finance / pytdx / Tickflow" style="rounded=1;fillColor=#eceff1;fontColor=#37474f;strokeColor=#90a4ae;fontSize=9;fontStyle=2;whiteSpace=wrap;" vertex="1" parent="1">
      <mxGeometry x="40" y="640" width="380" height="30" as="geometry"/>
    </mxCell>
    <mxCell id="ext_llm2" value="LLM: Gemini / Claude / GPT-4 (LiteLLM Router)  |  搜索: Bocha / Tavily / Brave / SerpAPI / SearXNG" style="rounded=1;fillColor=#eceff1;fontColor=#37474f;strokeColor=#90a4ae;fontSize=9;fontStyle=2;whiteSpace=wrap;" vertex="1" parent="1">
      <mxGeometry x="440" y="640" width="330" height="30" as="geometry"/>
    </mxCell>

    <!-- Edges -->
    <mxCell id="e_in1" style="endArrow=classic;strokeColor=#5c6bc0;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="input" target="fetch_group">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- Fetch -> Tech -->
    <mxCell id="e_f1" style="endArrow=classic;strokeColor=#1e88e5;exitX=0.5;exitY=1;entryX=0.2;entryY=0;" edge="1" parent="1" source="fetch_daily" target="tech">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="e_f2" style="endArrow=classic;strokeColor=#1e88e5;exitX=0.3;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="fetch_rt" target="tech">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- Fetch -> Merge (chip, fund go direct to merge) -->
    <mxCell id="e_f3" style="endArrow=classic;strokeColor=#1e88e5;exitX=0.5;exitY=1;entryX=0;entryY=0;curved=1;" edge="1" parent="1" source="fetch_chip" target="merge">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="e_f4" style="endArrow=classic;strokeColor=#1e88e5;exitX=0.5;exitY=1;entryX=1;entryY=0;curved=1;" edge="1" parent="1" source="fetch_fund" target="merge">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- Tech -> Merge -->
    <mxCell id="e_t1" style="endArrow=classic;strokeColor=#43a047;exitX=0.8;exitY=1;entryX=0;entryY=0.5;" edge="1" parent="1" source="tech" target="merge">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <!-- News -> Merge -->
    <mxCell id="e_n1" style="endArrow=classic;strokeColor=#43a047;exitX=0.3;exitY=1;entryX=1;entryY=0.5;" edge="1" parent="1" source="news" target="merge">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- Merge -> AI -->
    <mxCell id="e_m1" style="endArrow=classic;strokeColor=#ef6c00;strokeWidth=2;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="merge" target="ai">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- AI -> Integrity -->
    <mxCell id="e_a1" style="endArrow=classic;strokeColor=#ef6c00;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="ai" target="integrity">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- Integrity -> Format + Notify -->
    <mxCell id="e_i1" style="endArrow=classic;strokeColor=#7b1fa2;exitX=0.2;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="integrity" target="format_step">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="e_i2" style="endArrow=classic;strokeColor=#7b1fa2;exitX=0.8;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="integrity" target="notify_step">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- Format + Notify -> Persist -->
    <mxCell id="e_p1" style="endArrow=classic;strokeColor=#455a64;exitX=0.5;exitY=1;entryX=0.3;entryY=0;" edge="1" parent="1" source="format_step" target="persist">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="e_p2" style="endArrow=classic;strokeColor=#455a64;exitX=0.5;exitY=1;entryX=0.7;entryY=0;" edge="1" parent="1" source="notify_step" target="persist">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- Data type annotations -->
    <mxCell id="dt1" value="DataFrame&#xa;(OHLC)" style="text;fontSize=8;fontStyle=2;fillColor=none;strokeColor=none;fontColor=#1565c0;align=center;" vertex="1" parent="1">
      <mxGeometry x="68" y="198" width="65" height="28" as="geometry"/>
    </mxCell>
    <mxCell id="dt2" value="Realtime&#xa;Quote" style="text;fontSize=8;fontStyle=2;fillColor=none;strokeColor=none;fontColor=#1565c0;align=center;" vertex="1" parent="1">
      <mxGeometry x="225" y="198" width="60" height="28" as="geometry"/>
    </mxCell>
    <mxCell id="dt3" value="TrendAnalysis&#xa;Result" style="text;fontSize=8;fontStyle=2;fillColor=none;strokeColor=none;fontColor=#2e7d32;align=center;" vertex="1" parent="1">
      <mxGeometry x="270" y="296" width="80" height="28" as="geometry"/>
    </mxCell>
    <mxCell id="dt4" value="Search&#xa;Response" style="text;fontSize=8;fontStyle=2;fillColor=none;strokeColor=none;fontColor=#2e7d32;align=center;" vertex="1" parent="1">
      <mxGeometry x="430" y="296" width="65" height="28" as="geometry"/>
    </mxCell>
    <mxCell id="dt5" value="AnalysisResult" style="text;fontSize=9;fontStyle=3;fillColor=none;strokeColor=none;fontColor=#ef6c00;align=center;" vertex="1" parent="1">
      <mxGeometry x="320" y="435" width="90" height="16" as="geometry"/>
    </mxCell>
  </root>
</mxGraphModel>